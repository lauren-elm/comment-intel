# ===== Ad Comment Intel — config example =====
# Copy to `config.env` and fill in, OR just run:  intel setup
# Nothing here is committed — config.env is gitignored.

# --- Meta / Facebook ---
# A long-lived (System User) access token with: ads_read, read_insights,
# pages_show_list, pages_read_user_content.  See docs/01-create-meta-app.md
META_ACCESS_TOKEN=
# Your ad account id, digits only (the "act_" prefix is added automatically)
META_AD_ACCOUNT_ID=
# The Facebook Page whose ad-post comments you want (auto-filled by `intel setup`)
META_PAGE_ID=
GRAPH_VERSION=v21.0

# --- Brand / pull window ---
BRAND_NAME=Your Brand
# How far back to analyze spend (rolling months, includes the current month)
MONTHS_BACK=13
# A post must have at least this much total spend to be considered
MIN_SPEND=300
# "Positive ROI" = FB-attributed ROAS strictly greater than this
MIN_ROAS=1.0
# Always also include the top-N highest spenders (even if not profitable)
TOP_BY_SPEND=20
# Skip posts with fewer than this many comments
MIN_COMMENTS=1
# Cap comments pulled per post (protects against giant threads)
MAX_PER_POST=2000

# --- Cloudflare R2 (free media + gallery hosting) ---
# See docs/02-cloudflare-r2.md
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ad-comment-intel
# Usually https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Your bucket's public URL — a custom domain (files.yourdomain.com) or the r2.dev dev URL
R2_PUBLIC_BASE=
